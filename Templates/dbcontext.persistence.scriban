            }

            var tenantIdProperty = entityType.GetProperty("TenantId");
            if (tenantIdProperty is null)
            {
                continue;
            }

            var currentValue = tenantIdProperty.PropertyType == typeof(int)
                ? (int?)tenantIdProperty.GetValue(entity)
                : tenantIdProperty.GetValue(entity) as int?;

            if (CurrentTenantId == 0 && (!currentValue.HasValue || currentValue.Value == 0))
            {
                throw new InvalidOperationException($"Cannot save '{entityType.Name}' because tenant cannot be resolved.");
            }

            if (!currentValue.HasValue || currentValue.Value == 0)
            {
                tenantIdProperty.SetValue(entity, CurrentTenantId);
            }
            else if (CurrentTenantId > 0 && currentValue.Value != CurrentTenantId)
            {
                throw new InvalidOperationException($"Cross-tenant save detected for '{entityType.Name}'.");
            }
        }
