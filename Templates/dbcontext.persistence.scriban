    private void CreateAuditLog(long? userId, IEnumerable<object>? entities)
    {
        ChangeTracker.DetectChanges();

        var relevantEntries = ChangeTracker.Entries()
            .Where(entry =>
                entry.Entity is not AuditLog &&
                entry.State != EntityState.Detached &&
                entry.State != EntityState.Unchanged &&
                entry.Entity.GetType().Name != nameof(UserRefreshToken) &&
                (entities == null || entities.Contains(entry.Entity)))
            .Select(entry => new AuditEntry(entry)
            {
                TableName = entry.Entity.GetType().Name,
                TenantId = CurrentTenantId,
                UserId = userId
            })
            .ToList();

        foreach (var auditEntry in relevantEntries)
        {
            var entry = auditEntry.Entry;
            auditEntry.AuditLogType = entry.State switch
            {
                EntityState.Added => AuditLogType.Create,
                EntityState.Deleted => AuditLogType.Delete,
                EntityState.Modified => AuditLogType.Update,
                _ => auditEntry.AuditLogType
            };

            foreach (var property in entry.Properties)
            {
                var propertyName = property.Metadata.Name;

                if (propertyName.Contains("Key", StringComparison.OrdinalIgnoreCase)
                    || propertyName.Contains("Password", StringComparison.OrdinalIgnoreCase)
                    || propertyName.Contains("Token", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                if (property.Metadata.IsPrimaryKey())
                {
                    auditEntry.KeyValues[propertyName] = property.CurrentValue ?? string.Empty;
                    continue;
                }

                if (property.Metadata.IsForeignKey())
                {
                    auditEntry.ChangedColumns.Add(propertyName);
                    auditEntry.OldValues[propertyName] = property.OriginalValue ?? string.Empty;
                    auditEntry.NewValues[propertyName] = property.CurrentValue ?? string.Empty;
                }

                switch (entry.State)
                {
                    case EntityState.Added:
                        auditEntry.NewValues[propertyName] = property.CurrentValue ?? string.Empty;
                        break;
                    case EntityState.Deleted:
                        auditEntry.OldValues[propertyName] = property.OriginalValue ?? string.Empty;
                        break;
                    case EntityState.Modified when property.IsModified:
                        auditEntry.ChangedColumns.Add(propertyName);
                        auditEntry.OldValues[propertyName] = property.OriginalValue ?? string.Empty;
                        auditEntry.NewValues[propertyName] = property.CurrentValue ?? string.Empty;
                        break;
                }
            }

            AuditLogs.Add(auditEntry.ToAudit());
        }
    }
