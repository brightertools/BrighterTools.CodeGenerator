    private void ApplyTenantId(IEnumerable<object>? entities)
    {
        foreach (var entity in entities ?? Enumerable.Empty<object>())
        {
            var entityType = entity.GetType();
            if (!TenantScopedEntityTypes.Contains(entityType))
            {
